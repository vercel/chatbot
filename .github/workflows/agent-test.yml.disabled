# === DISABLED 2026-06-21 23:08 UTC ===
# Phase 40 Agent Tests are failing reliably in CI (20+ min timeout)
# due to missing live infrastructure (Clerk auth, Twenty workspace, V2 auth).
# Each failure generates an email notification — 73 runs in 24h.
#
# DISABLED via if:false at job level to stop email avalanche.
# Re-enable when fixed per M-WORKFLOW-FIX-DEFERRED mission.
# Tracker: jarvis/cortex/missions/M-WORKFLOW-FIX-DEFERRED.md
#
# Original trigger: pull_request (main), push (main), workflow_dispatch
# =========================================

name: Phase 40 Agent Tests
on:
  pull_request:
    branches: [main]
    paths:
      - 'app/**'
      - 'lib/**'
      - 'components/**'
      - 'cortex/playbooks/testing/**'
  push:
    branches: [main]
    paths:
      - 'app/**'
      - 'lib/**'
      - 'components/**'
  workflow_dispatch:
    inputs:
      test_type:
        description: 'Type of tests to run'
        required: true
        default: 'smoke'
        type: choice
        options:
          - smoke
          - regression
          - full

jobs:
  agent-test:
    if: false  # DISABLED 2026-06-21 23:08 UTC — failing reliably, causing email spam. Re-enable when fixed per M-WORKFLOW-FIX-DEFERRED mission.
    timeout-minutes: 20
    runs-on: ubuntu-latest
    env:
      TEST_ENV: ci
      TEST_BACKEND: playwright
      TEST_AUDIT_ENABLED: 'true'

    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 1

      - uses: actions/setup-node@v4
        with:
          node-version: '24'

      - name: Install pnpm
        uses: pnpm/action-setup@v2
        with:
          version: latest
          run_install: false

      - name: Get pnpm store directory
        id: pnpm-cache
        shell: bash
        run: echo "STORE_PATH=$(pnpm store path)" >> $GITHUB_OUTPUT

      - uses: actions/cache@v3
        with:
          path: ${{ steps.pnpm-cache.outputs.STORE_PATH }}
          key: ${{ runner.os }}-pnpm-${{ hashFiles('pnpm-lock.yaml') }}
          restore-keys: |
            ${{ runner.os }}-pnpm-

      - name: Install dependencies
        run: pnpm install --frozen-lockfile

      - name: Install Playwright browsers
        run: pnpm exec playwright install chromium --with-deps

      - name: Build project
        run: pnpm build
        env:
          SKIP_TYPE_CHECK: 'true'

      - name: Run Smoke Tests
        if: ${{ github.event.inputs.test_type == 'smoke' || github.event_name == 'pull_request' }}
        run: |
          echo "Running smoke tests..."
          pnpm exec tsx lib/testing/ci-smoke-runner.ts
        env:
          TESTER_USER_CREDENTIALS: ${{ secrets.TESTER_USER_CREDENTIALS }}
          AI_GATEWAY_KEY: ${{ secrets.AI_GATEWAY_KEY }}

      - name: Run Regression Tests
        if: ${{ github.event.inputs.test_type == 'regression' }}
        run: |
          echo "Running regression tests..."
          pnpm exec tsx lib/testing/ci-regression-runner.ts
        env:
          TESTER_USER_CREDENTIALS: ${{ secrets.TESTER_USER_CREDENTIALS }}
          AI_GATEWAY_KEY: ${{ secrets.AI_GATEWAY_KEY }}

      - name: Post Results as PR Comment
        if: github.event_name == 'pull_request'
        uses: actions/github-script@v7
        with:
          script: |
            const fs = require('fs');
            const results = JSON.parse(fs.readFileSync('/tmp/test-results.json', 'utf-8'));

            const emoji = results.passRate >= 95 ? '🟢' : results.passRate >= 80 ? '🟡' : '🔴';

            const comment = `## ${emoji} Phase 40 Test Results

            | Metric | Value |
            |--------|-------|
            | **Pass Rate** | ${results.passRate}% |
            | **Passed** | ${results.passed}/${results.total} |
            | **Duration** | ${results.duration}s |
            | **Cost** | $${results.cost} |

            ${results.failed > 0 ? '### ❌ Failures\n' + results.failures.map(f => `- **${f.scenario}**: ${f.error}`).join('\n') : '### ✅ All tests passed'}

            🤖 Generated by Phase 40 Testing Agent`;

            github.rest.issues.createComment({
              issue_number: context.issue.number,
              owner: context.repo.owner,
              repo: context.repo.repo,
              body: comment,
            });

      - name: Notify Slack on Failure
        if: failure()
        run: |
          curl -X POST "${{ secrets.SLACK_TEST_WEBHOOK }}" \
            -H "Content-Type: application/json" \
            -d '{"text":"🔴 Phase 40 tests FAILED on ${{ github.ref_name }}\n${{ github.server_url }}/${{ github.repository }}/actions/runs/${{ github.run_id }}"}'
