{
  "framework": "nextjs",
  "headers": [
    {
      "source": "/command-center(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "frame-src https://app.crm.newleaf.financial https://crm.newleaf.financial; frame-ancestors 'self'"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/annotations/digest?period=week",
      "schedule": "0 12 * * 1"
    },
    {
      "path": "/api/knowledge/extract?hoursBack=24&limit=50",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/refinement-loop",
      "schedule": "0 2 * * 0"
    }
  ]
}
