# generate a random secret: https://generate-secret.vercel.app/32 or `openssl rand -base64 32`
AUTH_SECRET=****

# required for non-vercel deployments, vercel uses OIDC automatically
# https://vercel.com/ai-gateway
AI_GATEWAY_API_KEY=****

# DeepSeek API key — required ONLY for direct-routed models (deepseek-v4-pro, deepseek-reasoner).
# When not set, these models gracefully fall back to the Vercel AI Gateway.
# Create at https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# https://vercel.com/docs/vercel-blob
BLOB_READ_WRITE_TOKEN=****

# https://vercel.com/docs/postgres
POSTGRES_URL=****

# https://vercel.com/docs/redis
REDIS_URL=****

# ─── Handoff & Deploy Tokens ─────────────────────────────────────────────────
# Required for spawnCodingAgent tool (new_project + modify_existing modes)
# and code-handoff-bridge.ts (Neptune Chat → V2 delegation).

# VERCEL_TOKEN: Full Account scope token from https://vercel.com/account/tokens
VERCEL_TOKEN=
# VERCEL_TEAM_ID: Your Vercel team ID (slug or team_xxx)
VERCEL_TEAM_ID=
# GITHUB_TOKEN: GitHub PAT with "repo" scope from https://github.com/settings/tokens
GITHUB_TOKEN=

# ─── V2 Handoff Bridge ───────────────────────────────────────────────────────
# OPEN_AGENTS_URL: Base URL for Neptune V2 (default: https://neptune-v2.vercel.app)
OPEN_AGENTS_URL=https://neptune-v2.vercel.app
# OPEN_AGENTS_API_KEY: API key for V2 sandbox API authentication
OPEN_AGENTS_API_KEY=
# NEPTUNE_V2_HANDOFF_SECRET: Shared secret for Chat → V2 handoff bridge
NEPTUNE_V2_HANDOFF_SECRET=
# NEPTUNE_V2_CHAT_URL: Override for V2 chat endpoint
NEPTUNE_V2_CHAT_URL=https://neptune-v2.vercel.app/api/chat
# NEPTUNE_V2_TASKS_URL: Override for V2 tasks create endpoint
NEPTUNE_V2_TASKS_URL=https://neptune-v2.vercel.app/api/tasks/create

# ─── YouTube Research Connector ────────────────────────────────────────────────
# Required for youtube-research connector (searchVideos, getTranscript, etc.)
# Create at https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=
