{
  "name": "assistant-extension-platform",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "pnpm --filter @app/extension dev",
    "dev:extension": "pnpm --filter @app/extension dev",
    "dev:api": "pnpm --filter @app/agent-api dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test"
  }
}
