{
  "name": "neptune-chat",
  "version": "3.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbo",
    "prebuild": "tsx scripts/generate-capabilities.ts && (tsx scripts/validate-playbooks.ts || echo '⚠️  playbook validation warnings (non-fatal)') && (tsx lib/db/seeds/seed-library.ts || true)",
    "playbooks:validate": "tsx scripts/validate-playbooks.ts",
    "capabilities:regen": "tsx scripts/generate-capabilities.ts",
    "db:seed-library": "(tsx lib/db/seeds/seed-library.ts || true)",
    "build": "tsx lib/db/migrate && next build",
    "start": "next start",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "npx tsx lib/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push",
    "db:pull": "drizzle-kit pull",
    "db:check": "drizzle-kit check",
    "db:up": "drizzle-kit up",
    "test": "export PLAYWRIGHT=True && pnpm exec playwright test",
    "neptune:bootstrap": "tsx scripts/bootstrap-neptune.ts",
    "neptune:bootstrap:dry": "tsx scripts/bootstrap-neptune.ts --dry-run",
    "seed:models": "tsx scripts/seed-models.ts",
    "seed:models:dry": "tsx scripts/seed-models.ts --dry-run",
    "seed:evals": "tsx scripts/seed-evals.ts",
    "seed:evals:dry": "tsx scripts/seed-evals.ts --dry-run",
    "kg:recompute-weights": "tsx scripts/recompute-edge-weights.ts",
    "health": "curl -s http://localhost:3000/api/health | jq .",
    "vps-health": "curl -s http://localhost:3000/api/admin/vps-health | jq .",
    "pre-push": "bash .github/hooks/pre-push"
  },
